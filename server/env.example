# Database Configuration
MONGODB_URI=mongodb://localhost:27017/mafqoudat
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/mafqoudat

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Token Expiration Settings
# Access token expiry (how long the user stays logged in without refreshing)
# Options: 15m, 30m, 1h, 2h, 4h, 8h, 12h, 24h, 1d, 2d, 7d
# Recommended: 4h for good balance of security and user experience
JWT_ACCESS_EXPIRES_IN=4h

# Refresh token expiry (how long the refresh token is valid - THIS IS HOW LONG USERS STAY LOGGED IN)
# Options: 1d, 3d, 7d, 14d, 30d
# Recommended: 7d (1 week) for good user experience
JWT_REFRESH_EXPIRES_IN=7d

# Legacy support - if you want to use the old JWT_EXPIRES_IN for access token
# JWT_EXPIRES_IN=1h

# Cookie Security Configuration (Production)
COOKIE_DOMAIN=.mafqoudat.com

# Server Configuration
PORT=3500
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Notification Configuration
# These are required for "Report Post" and "Increase Chances" features
ADMIN_EMAIL=your_admin_email@gmail.com
SUPPORT_EMAIL=support@mafqoudat.com

# Email Service Configuration (Gmail recommended)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
# For Gmail, use an App Password instead of your regular password
# Go to Google Account > Security > 2-Step Verification > App passwords
EMAIL_PASS=your_gmail_app_password

# Optional: For other email services
# EMAIL_SERVICE=outlook
# EMAIL_SERVICE=yahoo
# EMAIL_SERVICE=hotmail

# Redis Configuration (Optional - for distributed caching)
# If not provided, the app will use in-memory cache only
REDIS_URL=redis://localhost:6379 

# GeoNames API Configuration (for city search)
GEONAMES_USERNAME=your_geonames_username
GEONAMES_API_URL=http://api.geonames.org


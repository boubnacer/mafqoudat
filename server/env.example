# Database Configuration
MONGODB_URI=mongodb://localhost:27017/mafqoudat
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/mafqoudat

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Token Expiration Settings
# Access token expiry - long-lived tokens for simplicity
# Options: 1d, 7d, 14d, 30d
# Recommended: 30d (30 days) for best user experience
JWT_ACCESS_EXPIRES_IN=30d

# Cookie Security Configuration (Production)
COOKIE_DOMAIN=.mafqoudat.com

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3500/auth/google/callback
# For production: https://mafqoudat-production.up.railway.app/auth/google/callback

# Session Secret (for OAuth sessions)
SESSION_SECRET=your_session_secret_here

# Server Configuration
PORT=3500
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Notification Configuration
# These are required for "Report Post" and "Increase Chances" features
ADMIN_EMAIL=your_admin_email@gmail.com
SUPPORT_EMAIL=support@mafqoudat.com

# Email Service Configuration (Gmail recommended)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
# For Gmail, use an App Password instead of your regular password
# Go to Google Account > Security > 2-Step Verification > App passwords
EMAIL_PASS=your_gmail_app_password

# Optional: For other email services
# EMAIL_SERVICE=outlook
# EMAIL_SERVICE=yahoo
# EMAIL_SERVICE=hotmail

# Redis Configuration (Optional - for distributed caching)
# If not provided, the app will use in-memory cache only
REDIS_URL=redis://localhost:6379 

# GeoNames API Configuration (for city search)
GEONAMES_USERNAME=your_geonames_username
GEONAMES_API_URL=http://api.geonames.org


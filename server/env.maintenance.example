# Maintenance Mode Configuration Example
# Add this to your .env file

# ============================================
# MAINTENANCE MODE
# ============================================

# Set to 'true' to enable maintenance mode
# Set to 'false' or remove to disable
# Default: false (disabled)
MAINTENANCE_MODE=false

# Usage:
# - When enabled, only admin users can access the application
# - Health checks, auth routes, and password reset remain accessible
# - Returns 503 status to non-admin users
# - All events are logged to server/logs/reqLog.log

# Examples:
# MAINTENANCE_MODE=true   # Enable maintenance
# MAINTENANCE_MODE=false  # Disable maintenance
# MAINTENANCE_MODE=       # Disable maintenance (empty value)


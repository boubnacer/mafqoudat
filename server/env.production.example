# Production Environment Variables — TEMPLATE ONLY
# Copy this to configure your Render dashboard env vars (or a local .env for reference).
# Do NOT put real secret values in this file — it is committed to git.

NODE_ENV=production
# Render injects PORT automatically; 10000 is Render's typical default.
PORT=10000
NODE_OPTIONS=--max-old-space-size=400 --expose-gc
NODE_NO_WARNINGS=1

MONGODB_URI=
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=30d

FRONTEND_URL=https://mafqoudat.com
CLIENT_URL=https://mafqoudat.com
CORS_ALLOWED_ORIGINS=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ADMIN_EMAIL=
EMAIL_PASS=
EMAIL_SERVICE=gmail
EMAIL_USER=
SUPPORT_EMAIL=

GEONAMES_API_URL=http://api.geonames.org
GEONAMES_USERNAME=

# Render service URL: https://mafqoudat-api.onrender.com/auth/google/callback
GOOGLE_CALLBACK_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Native mobile Google OAuth clients (iOS/Android), accepted alongside
# GOOGLE_CLIENT_ID when verifying mobile ID tokens.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_PLACES_API_KEY=

MAINTENANCE_MODE=false

# Not currently read by server code (session secret falls back to JWT_SECRET) —
# left here only in case that changes:
SESSION_SECRET=

{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/build",
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/asset-manifest.json",
      "destination": "/asset-manifest.json"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/logo192.png",
      "destination": "/logo192.png"
    },
    {
      "source": "/logo512.png",
      "destination": "/logo512.png"
    },
    {
      "source": "/language-test.html",
      "destination": "/language-test.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://mafqoudat-production.up.railway.app",
    "REACT_APP_DOMAIN": "https://mafqoudat.com",
    "REACT_APP_CLOUDINARY_CLOUD_NAME": "du0tmvxhu",
    "REACT_APP_CLOUDINARY_UPLOAD_PRESET": "mafqoudat",
    "REACT_APP_CLOUDINARY_API_KEY": "593667419254217",
    "CI": "false",
    "DISABLE_ESLINT_PLUGIN": "true",
    "GENERATE_SOURCEMAP": "false",
    "SKIP_PREFLIGHT_CHECK": "true",
    "NODE_ENV": "production"
  }
}

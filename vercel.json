{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build",
        "installCommand": "cd client && npm install",
        "buildCommand": "cd client && npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/client/build/static/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/client/build/manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "/client/build/favicon.ico"
    },
    {
      "src": "/logo192.png",
      "dest": "/client/build/logo192.png"
    },
    {
      "src": "/logo512.png",
      "dest": "/client/build/logo512.png"
    },
    {
      "src": "/(.*)",
      "dest": "/client/build/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://mafqoudat-production.up.railway.app",
    "REACT_APP_DOMAIN": "https://mafqoudat.com",
    "REACT_APP_CLOUDINARY_CLOUD_NAME": "du0tmvxhu",
    "REACT_APP_CLOUDINARY_UPLOAD_PRESET": "mafqoudat",
    "REACT_APP_CLOUDINARY_API_KEY": "593667419254217",
    "CI": "false",
    "DISABLE_ESLINT_PLUGIN": "true"
  }
}

{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/logo192.png",
      "dest": "/logo192.png"
    },
    {
      "src": "/logo512.png",
      "dest": "/logo512.png"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://mafqoudat-production.up.railway.app",
    "REACT_APP_DOMAIN": "https://mafqoudat.com",
    "REACT_APP_CLOUDINARY_CLOUD_NAME": "du0tmvxhu",
    "REACT_APP_CLOUDINARY_UPLOAD_PRESET": "mafqoudat",
    "REACT_APP_CLOUDINARY_API_KEY": "593667419254217"
  }
}

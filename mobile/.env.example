# Mobile App Environment Variables
# Expo inlines EXPO_PUBLIC_-prefixed vars directly into the JS bundle at build time
# (see src/config/api.js). None of these have hardcoded fallbacks in source anymore -
# copy this file to .env and fill in every value below, or the app will fail at
# runtime (network errors, missing OAuth client) rather than silently using stale
# defaults. For EAS builds, set the same values as EAS environment variables/secrets
# per profile instead of (or in addition to) a local .env - see mobile/BUILD.md.

# Backend API base URL, no trailing slash. Required.
EXPO_PUBLIC_API_URL=https://mafqoudat-api.onrender.com

# Canonical marketing site, used for the Settings screen's Privacy Policy / Terms of
# Service links (client/src/utils/seoConfig.js has the same value on the web side).
# Required.
EXPO_PUBLIC_WEB_BASE_URL=https://www.mafqoudat.com

# Google OAuth client IDs (expo-auth-session native ID-token flow). The web client ID
# doubles as the Expo Go / fallback client when the platform-specific one below isn't
# set - it is still required. The platform-specific ones are required for a standalone/
# EAS build on that platform (Expo Go ignores them).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=571757802995-qg4dvpnaidjh532uo0eu88l1qttmckac.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=571757802995-snknt81pnlehkb6scmqfhpcjg8sbgla0.apps.googleusercontent.com

# Google sign-in flow: "true" (default) uses the native expo-auth-session ID-token
# exchange; set to "false" to fall back to the legacy in-app-browser + deep-link flow.
# Optional - defaults to true (native) if unset.
EXPO_PUBLIC_USE_NATIVE_GOOGLE_AUTH=true

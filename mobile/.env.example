# Mobile App Environment Variables
# Expo uses EXPO_PUBLIC_ prefix for environment variables that should be exposed to the app
# Copy this file to .env and fill in your actual values

# API Configuration
# Your backend API URL (without trailing slash)
EXPO_PUBLIC_API_URL=https://mafqoudat-api.onrender.com

# Frontend URL (for OAuth redirects)
# This should match your server's FRONTEND_URL or CLIENT_URL environment variable
# This is the URL where your web app is hosted
# IMPORTANT: This must match exactly what the server redirects to for OAuth to work
EXPO_PUBLIC_FRONTEND_URL=https://mafqoudat.com

# Optional: Google Analytics (if you want to add analytics later)
# EXPO_PUBLIC_GA_MEASUREMENT_ID=your-ga-id

# Google OAuth client IDs (expo-auth-session native ID-token flow)
# Web client ID also doubles as the Expo Go / fallback client when the platform-specific
# one below isn't set. src/config/api.js keeps a dev-only hardcoded fallback for this one
# so the app doesn't crash if it's missing; the platform ones have no fallback.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=571757802995-qg4dvpnaidjh532uo0eu88l1qttmckac.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=571757802995-snknt81pnlehkb6scmqfhpcjg8sbgla0.apps.googleusercontent.com

# Google sign-in flow: "true" (default) uses the native expo-auth-session ID-token
# exchange; set to "false" to fall back to the legacy in-app-browser + deep-link flow.
EXPO_PUBLIC_USE_NATIVE_GOOGLE_AUTH=true
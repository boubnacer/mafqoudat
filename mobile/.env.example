# Mobile App Environment Variables
# Expo uses EXPO_PUBLIC_ prefix for environment variables that should be exposed to the app
# Copy this file to .env and fill in your actual values

# API Configuration
# Your backend API URL (without trailing slash)
EXPO_PUBLIC_API_URL=https://mafqoudat-api.onrender.com

# Frontend URL (for OAuth redirects)
# This should match your server's FRONTEND_URL or CLIENT_URL environment variable
# This is the URL where your web app is hosted
# IMPORTANT: This must match exactly what the server redirects to for OAuth to work
EXPO_PUBLIC_FRONTEND_URL=https://mafqoudat.com

# Optional: Google Analytics (if you want to add analytics later)
# EXPO_PUBLIC_GA_MEASUREMENT_ID=your-ga-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=571757802995-snknt81pnlehkb6scmqfhpcjg8sbgla0.apps.googleusercontent.com